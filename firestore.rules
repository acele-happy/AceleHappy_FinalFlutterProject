rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDocExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return userDocExists() && userDoc().role == 'admin';
    }

    function isStartupFounder(startupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/startups/$(startupId))
        && get(/databases/$(database)/documents/startups/$(startupId)).data.founderId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /startups/{startupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.founderId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.founderId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || isStartupFounder(resource.data.startupId)
        || isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (
        isStartupFounder(resource.data.startupId)
        || isAdmin()
      );
    }

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
